# Copy this file to config/.env and fill in your values.
# All settings have sensible defaults — only override what you need.

# SQLite (default) — relative to backend/data/
DATABASE_URL=sqlite:///./data/spend_tracker.db

# Absolute path to the folder watched for auto-ingestion
# WATCHED_FOLDER=/absolute/path/to/backend/data/watched_folder

# Comma-separated allowed origins for CORS
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Your name(s) EXACTLY as they appear in your bank statements. Drives self /
# internal-transfer (top-up) detection — these are excluded from spend & income.
# JSON array. Set this when taking the project over.
# ACCOUNT_HOLDER_NAMES=["YOURNAME","YOUR OTHER ACCOUNT NAME"]

# Investment / brokerage platform names — debits to these count as "invested",
# not "spent". JSON array; overrides the defaults in src/app/config.py.
# INVESTMENT_KEYWORDS=["ZERODHA","GROWW","UPSTOX"]

# Credit-card bill-payment markers — money settling a card, not category spend.
# CARD_PAYMENT_KEYWORDS=["CRED","CREDIT CARD"]
